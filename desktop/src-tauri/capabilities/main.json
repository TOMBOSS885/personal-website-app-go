{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Minimum permissions for the public blog window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://**" },
        { "url": "http://127.0.0.1:*" },
        { "url": "http://localhost:*" }
      ]
    },
    "store:default",
    "sql:default"
  ]
}
