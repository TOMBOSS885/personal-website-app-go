# Environment for the Go backend version.
# Copy this file to .env and replace the placeholder values.

# Go API runtime.
SERVER_PORT=8080
GIN_MODE=release
APP_UPLOAD_DIR=/app/uploads
AUTO_MIGRATE=true
CORS_ALLOWED_ORIGINS=*

# MySQL.
# For Baota/host MySQL with the current host-network compose file, use 127.0.0.1.
# If MySQL is another server, replace MYSQL_HOST with that server IP/domain.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=personal_website
MYSQL_USERNAME=root
MYSQL_PASSWORD=replace_with_mysql_password

# JWT. Must be at least 32 characters. Use: openssl rand -base64 48
JWT_SECRET=replace_with_a_random_secret_at_least_32_chars
JWT_EXPIRATION=86400000

# Initial admin.
# The admin user is created only when ADMIN_USERNAME does not exist.
# Set ADMIN_RESET_PASSWORD=true temporarily if the user exists but the password is unknown.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@example.com
ADMIN_RESET_PASSWORD=false
